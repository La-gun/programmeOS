# Database (Prisma)
DATABASE_URL="postgresql://user:pass@localhost:5432/programmeos"

# NextAuth (existing app)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-secret"

# Public site URL for QR codes / “open app” links on phones. Use your deployed or tunnel URL when localhost won’t work from mobile.
# NEXT_PUBLIC_APP_URL="https://your-app.example.com"

# Meta App Secret — used to verify X-Hub-Signature-256 on POST /api/webhooks/messaging/whatsapp (required in production for real Meta traffic).
META_APP_SECRET=""

# Optional: Bearer for manual webhook tests or dev mock payloads when META_APP_SECRET is unset (not sent by Meta).
MESSAGING_INBOUND_SECRET=""

# Default tenant for Meta webhooks when X-Tenant-Id is not sent (single-tenant / dev).
# After seed, you can copy the tenant id from the DB or set this empty to use demo.domain lookup.
MESSAGING_DEFAULT_TENANT_ID=""

# Redis for idempotent inbound processing (recommended when running multiple instances).
# Omit to use an in-process fallback (fine for single local dev server).
REDIS_URL="redis://localhost:6379"

# Outbound: mock WhatsApp (logs + in-memory outbox). Set to "false" to send via Cloud API.
WHATSAPP_MOCK_MODE="true"

# WhatsApp Cloud API (when WHATSAPP_MOCK_MODE=false) — same app as webhooks; token needs whatsapp_business_messaging, etc.
META_WHATSAPP_PHONE_NUMBER_ID=""
META_WHATSAPP_ACCESS_TOKEN=""
# Optional override, default v21.0
# META_GRAPH_API_VERSION="v21.0"

# Meta webhook verification (GET hub.challenge)
META_WEBHOOK_VERIFY_TOKEN=""

# Click-to-chat QR on Dashboard → Messages (public: embedded in client bundle). Full international MSISDN, digits only — same WhatsApp Business line users message (not phone_number_id).
# NEXT_PUBLIC_WHATSAPP_BUSINESS_MSISDN="447911123456"
# Optional default text when the chat opens
# NEXT_PUBLIC_WHATSAPP_CHAT_PREFILL="Hello, I'm reaching out from the programme."
