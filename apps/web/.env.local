# Database
DATABASE_URL="postgresql://username:password@localhost:5432/programmeos"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# Dev only: skip login; uses first DB user (or DEV_IMPERSONATE_EMAIL). Remove or set DISABLE_AUTH=false to require real sign-in.
DISABLE_AUTH=true