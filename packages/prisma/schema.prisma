// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum Role {
  ADMIN
  MANAGER
  FACILITATOR
  PARTICIPANT
}

enum ConsentType {
  TERMS_OF_SERVICE
  DATA_PROCESSING
  MARKETING
  RESEARCH
}

enum MilestoneStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  OVERDUE
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  REQUIRES_CHANGES
}

enum MessageType {
  TEXT
  FILE
  SYSTEM
}

enum MessagingChannel {
  INTERNAL
  WHATSAPP
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  SUBMIT_EVIDENCE
  REVIEW_EVIDENCE
  INTEGRITY_FLAG_RAISED
  INTEGRITY_CASE_OPENED
  INTEGRITY_CASE_RESOLVED
  INTEGRITY_CASE_DISMISSED
}

/// Declarative integrity rule identifiers (evaluated in application code).
enum IntegrityRuleCode {
  DUPLICATE_PHONE
  SUBMISSION_VELOCITY
}

enum IntegrityCaseStatus {
  OPEN
  RESOLVED
  DISMISSED
}

enum PayoutBatchStatus {
  DRAFT
  SUBMITTED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum PayoutItemStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}

/// Persisted AI assistant outputs (suggestions only; never authoritative).
enum AiSuggestionKind {
  EVIDENCE_SUMMARY
  REVIEWER_SUMMARY_DRAFT
  COHORT_SUMMARY
  PARTICIPANT_REPLY_DRAFT
}

// NextAuth.js models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationtokens")
}

// Models
model Tenant {
  id          String   @id @default(cuid())
  name        String
  domain      String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  users         User[]
  memberships   Membership[]
  programmes    Programme[]
  documents     Document[]
  conversations              Conversation[]
  participantChannelAddresses ParticipantChannelAddress[]
  auditEvents   AuditEvent[]
  payoutBatches PayoutBatch[]
  integrityCases IntegrityCase[]
  integrityFlags IntegrityFlag[]
  aiSuggestions AiSuggestion[]

  @@map("tenants")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatar    String?
  /// Bcrypt hash for credentials sign-in; omit for OAuth-only users
  passwordHash String?
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tenant                       Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberships                  Membership[]
  participants                 Participant[]
  evidenceReviews              EvidenceReview[]
  messageEvents                MessageEvent[]
  auditEvents                  AuditEvent[]
  accounts                     Account[]
  sessions                     Session[]
  uploadedDocuments            Document[]
  participantStatusChangesMade ParticipantStatusEvent[]
  payoutBatchesCreated         PayoutBatch[]            @relation("PayoutBatchCreatedBy")
  integrityCasesResolved       IntegrityCase[]          @relation("IntegrityCaseResolvedBy")
  aiSuggestionsCreated         AiSuggestion[]         @relation("AiSuggestionCreatedBy")

  @@map("users")
}

model Membership {
  id       String @id @default(cuid())
  userId   String
  tenantId String
  role     Role   @default(PARTICIPANT)

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@map("memberships")
}

model Programme {
  id          String   @id @default(cuid())
  name        String
  description String?
  tenantId    String
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  tenant             Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cohorts            Cohort[]
  milestoneTemplates MilestoneTemplate[]

  @@map("programmes")
}

model Cohort {
  id          String   @id @default(cuid())
  name        String
  programmeId String
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  programme   Programme     @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  participants Participant[]
  aiSuggestions AiSuggestion[]

  @@map("cohorts")
}

model MilestoneTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  programmeId String
  order       Int
  dueDays     Int?     // Days from cohort start
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  programme          Programme            @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  participantMilestones ParticipantMilestone[]

  @@map("milestone_templates")
}

model Participant {
  id        String   @id @default(cuid())
  userId    String
  cohortId  String
  enrolledAt DateTime @default(now())
  status    String   @default("active")

  // Relations
  user                  User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cohort                Cohort                   @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  profile               ParticipantProfile?
  consentRecords        ConsentRecord[]
  participantMilestones ParticipantMilestone[]
  statusEvents          ParticipantStatusEvent[]
  documents             Document[]
  conversations         Conversation[]
  channelAddresses      ParticipantChannelAddress[]
  integrityCasesPrimary IntegrityCase[]             @relation("IntegrityCasePrimary")
  integrityFlags        IntegrityFlag[]
  aiSuggestions         AiSuggestion[]

  @@unique([userId, cohortId])
  @@map("participants")
}

model ParticipantStatusEvent {
  id            String   @id @default(cuid())
  participantId String
  fromStatus    String?
  toStatus      String
  note          String?
  changedById   String?
  createdAt     DateTime @default(now())

  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  changedBy   User?       @relation(fields: [changedById], references: [id], onDelete: SetNull)

  @@index([participantId, createdAt])
  @@map("participant_status_events")
}

model ParticipantProfile {
  id            String  @id @default(cuid())
  participantId String  @unique
  bio           String?
  goals         String?
  skills        String?
  experience    String?

  // Relations
  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@map("participant_profiles")
}

model ConsentRecord {
  id            String       @id @default(cuid())
  participantId String
  type          ConsentType
  consented     Boolean      @default(false)
  consentedAt   DateTime?
  version       String
  ipAddress     String?
  userAgent     String?

  // Relations
  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([participantId, type, version])
  @@map("consent_records")
}

model Document {
  id           String   @id @default(cuid())
  name         String
  url          String
  /// Relative path under the configured upload root (not a public URL alone)
  storagePath  String?
  size         Int?
  mimeType     String?
  tenantId     String
  uploadedById String?
  participantId String?
  createdAt    DateTime @default(now())

  // Relations
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  uploadedBy  User?        @relation(fields: [uploadedById], references: [id])
  participant Participant? @relation(fields: [participantId], references: [id], onDelete: SetNull)

  @@index([tenantId, participantId])
  @@map("documents")
}

model ParticipantMilestone {
  id                   String          @id @default(cuid())
  participantId        String
  milestoneTemplateId  String
  status               MilestoneStatus @default(NOT_STARTED)
  startedAt            DateTime?
  completedAt          DateTime?
  dueDate              DateTime?
  notes                String?

  // Relations
  participant       Participant         @relation(fields: [participantId], references: [id], onDelete: Cascade)
  milestoneTemplate MilestoneTemplate   @relation(fields: [milestoneTemplateId], references: [id], onDelete: Cascade)
  evidenceSubmissions EvidenceSubmission[]

  @@unique([participantId, milestoneTemplateId])
  @@map("participant_milestones")
}

model EvidenceSubmission {
  id                   String           @id @default(cuid())
  participantMilestoneId String
  title                String
  description          String?
  status               SubmissionStatus @default(DRAFT)
  submittedAt          DateTime?
  documents            String[]         // Array of document IDs

  // Relations
  participantMilestone ParticipantMilestone @relation(fields: [participantMilestoneId], references: [id], onDelete: Cascade)
  reviews              EvidenceReview[]
  payoutItems          PayoutItem[]
  integrityTriggerCase IntegrityCase?
  integrityFlags       IntegrityFlag[]
  aiSuggestions        AiSuggestion[]

  @@map("evidence_submissions")
}

model EvidenceReview {
  id                   String        @id @default(cuid())
  evidenceSubmissionId String
  reviewerId           String
  status               ReviewStatus  @default(PENDING)
  feedback             String?
  reviewedAt           DateTime?
  score                Int?

  // Relations
  evidenceSubmission EvidenceSubmission @relation(fields: [evidenceSubmissionId], references: [id], onDelete: Cascade)
  reviewer           User               @relation(fields: [reviewerId], references: [id], onDelete: Cascade)
  aiSuggestions      AiSuggestion[]

  @@unique([evidenceSubmissionId, reviewerId])
  @@index([reviewerId, status])
  @@map("evidence_reviews")
}

model Conversation {
  id               String           @id @default(cuid())
  tenantId         String
  participantId    String?
  channel          MessagingChannel @default(INTERNAL)
  externalThreadId String?
  title            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // Relations
  tenant        Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  participant   Participant?           @relation(fields: [participantId], references: [id], onDelete: SetNull)
  messageEvents MessageEvent[]
  sessionState  MessagingSessionState?

  @@unique([tenantId, participantId, channel])
  @@map("conversations")
}

model ParticipantChannelAddress {
  id            String           @id @default(cuid())
  tenantId      String
  participantId String
  channel       MessagingChannel
  /// Normalised channel address (e.g. E.164 for WhatsApp)
  address       String
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, channel, address])
  @@unique([participantId, channel])
  @@map("participant_channel_addresses")
}

model MessagingSessionState {
  id             String   @id @default(cuid())
  conversationId String   @unique
  stateKey       String   @default("idle")
  data           Json?
  updatedAt      DateTime @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("messaging_session_states")
}

model MessageEvent {
  id                String           @id @default(cuid())
  conversationId    String
  senderId          String?
  direction         MessageDirection @default(INBOUND)
  /// Provider message id for idempotency / reconciliation (WhatsApp wamid.*)
  providerMessageId String?
  type              MessageType      @default(TEXT)
  content           String
  metadata          Json?
  sentAt            DateTime         @default(now())

  // Relations
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User?          @relation(fields: [senderId], references: [id], onDelete: SetNull)

  @@unique([conversationId, providerMessageId])
  @@map("message_events")
}

model AuditEvent {
  id        String      @id @default(cuid())
  tenantId  String
  userId    String?
  action    AuditAction
  entityType String      // e.g., "User", "Programme"
  entityId  String
  details   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime    @default(now())

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id])

  @@map("audit_events")
}

model PayoutBatch {
  id               String            @id @default(cuid())
  tenantId         String
  name             String?
  status           PayoutBatchStatus @default(DRAFT)
  /// Opaque reference from the payment provider (never store card or bank details here)
  providerBatchRef String?
  failureReason    String?
  createdById      String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User?        @relation("PayoutBatchCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  items     PayoutItem[]

  @@index([tenantId, status])
  @@map("payout_batches")
}

model PayoutItem {
  id                   String           @id @default(cuid())
  batchId              String
  evidenceSubmissionId String
  /// Amount in minor units (e.g. cents); optional until stipend rules are configured
  amountMinor          Int?
  currency             String           @default("USD")
  status               PayoutItemStatus @default(PENDING)
  providerItemRef      String?
  failureReason        String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  batch              PayoutBatch        @relation(fields: [batchId], references: [id], onDelete: Cascade)
  evidenceSubmission EvidenceSubmission @relation(fields: [evidenceSubmissionId], references: [id], onDelete: Cascade)

  @@unique([batchId, evidenceSubmissionId])
  @@index([evidenceSubmissionId])
  @@map("payout_items")
}

model IntegrityCase {
  id                          String              @id @default(cuid())
  tenantId                    String
  status                      IntegrityCaseStatus @default(OPEN)
  /// Submission that triggered this case (one open case per submission when rules fire).
  triggerEvidenceSubmissionId String?             @unique
  primaryParticipantId        String
  createdAt                   DateTime            @default(now())
  updatedAt                   DateTime            @updatedAt
  resolvedAt                  DateTime?
  resolvedById                String?
  resolutionNote              String?

  tenant                    Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  triggerEvidenceSubmission EvidenceSubmission?  @relation(fields: [triggerEvidenceSubmissionId], references: [id], onDelete: SetNull)
  primaryParticipant        Participant          @relation("IntegrityCasePrimary", fields: [primaryParticipantId], references: [id], onDelete: Cascade)
  resolvedBy                User?                @relation("IntegrityCaseResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)
  flags                     IntegrityFlag[]

  @@index([tenantId, status])
  @@map("integrity_cases")
}

model IntegrityFlag {
  id                   String            @id @default(cuid())
  tenantId             String
  caseId               String
  ruleCode             IntegrityRuleCode
  /// Short label for queues and tables.
  summary              String
  /// Fixed, human-readable explanation of what was detected (rules-based, auditable).
  explanation          String
  /// Structured facts used to produce the explanation (counts, ids, thresholds).
  metadata             Json?
  evidenceSubmissionId String
  participantId        String
  createdAt            DateTime          @default(now())

  tenant             Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  case               IntegrityCase      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  evidenceSubmission EvidenceSubmission @relation(fields: [evidenceSubmissionId], references: [id], onDelete: Cascade)
  participant        Participant        @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@index([tenantId, ruleCode])
  @@index([caseId])
  @@index([evidenceSubmissionId])
  @@map("integrity_flags")
}

model AiSuggestion {
  id                   String           @id @default(cuid())
  tenantId             String
  createdByUserId      String
  kind                 AiSuggestionKind
  /// Primary human-readable suggestion text (never treated as a decision).
  outputText           String           @db.Text
  outputStructured     Json?
  confidenceScore      Float?
  confidenceLabel      String?
  confidenceRationale  String?
  provider             String
  model                String?
  evidenceSubmissionId String?
  evidenceReviewId     String?
  cohortId             String?
  participantId        String?
  createdAt            DateTime         @default(now())

  tenant               Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy            User               @relation("AiSuggestionCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  evidenceSubmission   EvidenceSubmission? @relation(fields: [evidenceSubmissionId], references: [id], onDelete: SetNull)
  evidenceReview       EvidenceReview?       @relation(fields: [evidenceReviewId], references: [id], onDelete: SetNull)
  cohort               Cohort?             @relation(fields: [cohortId], references: [id], onDelete: SetNull)
  participant          Participant?        @relation(fields: [participantId], references: [id], onDelete: SetNull)

  @@index([tenantId, evidenceSubmissionId])
  @@index([tenantId, evidenceReviewId])
  @@index([tenantId, cohortId])
  @@index([tenantId, participantId])
  @@index([tenantId, createdAt])
  @@map("ai_suggestions")
}